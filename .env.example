# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env

# --- AWS credentials (needed to call Bedrock Claude) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=only-if-using-temporary-credentials

# --- Region where you enabled Bedrock model access ---
AWS_REGION=us-east-1

# --- The Claude model id you have enabled in Bedrock ---
# Must be a model you can see under Bedrock > Model access.
# Example inference-profile ids:
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
#   us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
